  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
    \u0432 \u043C\u043E\u044E \u0438\u0433\u0440\u0443!!!\n\u041D\u0430 \u0434\u0430\u043D\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442 \u043E\u043D\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432 \u043F\u0441\u0435\u0432\u0434\u043E\u0440\u0430\u0431\u043E\u0447\u0435\u043C
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438 \u0438\u043B\u0438 \u0436\u0435
    \"\u0410\u043B\u044C\u0444\u0435(Alfa)\"\n\u0412 \u043B\u0435\u0432\u043E\u043C
    \u043D\u0438\u0436\u043D\u0435\u043C \u0443\u0433\u043B\u0443 \u043C\u043E\u0436\u043D\u043E
    \u0431\u0443\u0434\u0435\u0442 \u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0441\u044F
    \u0441 \u0432\u0435\u0440\u0441\u0438\u0435\u0439 \u0438\u0433\u0440\u044B \"\u0411\u0438\u043B\u0434\u043E\u043C(Build)\"\n\n\u0412\u044B
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438 \u0434\u043E\u0441\u0442\u0443\u043F
    \u043A \u0438\u0433\u0440\u0435, \u043A\u0430\u043A \"\u0410\u043B\u044C\u0444\u0430
    \u0442\u0435\u0441\u0442\u0435\u0440\u044B\"-\u0422\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0432 \u0442\u043E\u0439
    \u0438\u043B\u0438 \u0438\u043D\u043D\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u044D\u0442\u043E\u043C\u0443 \u043F\u0440\u043E\u0435\u043A\u0442\u0443,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u044F \u0445\u043E\u0447\u0443 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0432\u0430\u043C \u0440\u0435\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044E
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432 \u0436\u0438\u0432\u0443\u044E.\n\u041F\u0440\u043E\u0448\u0443
    \u0432\u0430\u0441 \u043F\u0435\u0440\u0435\u0434 \u043F\u0440\u0438\u043D\u044F\u0442\u0438\u0435\u043C
    \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u044C
    \u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442-\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442
    \u043D\u0430\u0437\u0432\u0430\u0442\u044C \u043A\u0430\u043A \u0432\u0430\u043C
    \u0443\u0433\u043E\u0434\u043D\u043E \u0438 \u043D\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C-\u0412\u0430\u0448\u0435
    \u0438\u043C\u044F, \u0434\u0430\u0442\u0443 \u0442\u0435\u0441\u0442\u0430,
    \u043D\u043E\u043C\u0435\u0440 \u0431\u0438\u043B\u0434\u0430. \u0412\u0441\u0435
    \u0447\u0442\u043E \u0432\u0430\u043C \u043F\u043E\u043F\u0430\u0434\u0435\u0442\u0441\u044F
    \u0432 \u0433\u043B\u0430\u0437\u0430 \u043C\u043E\u0436\u0435\u0442\u0435 \u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432 \u044D\u0442\u043E\u043C \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0435-\u041E\u0448\u0438\u0431\u043A\u0438,\u0431\u0430\u0433\u0438,\u043D\u0435\u0434\u043E\u0447\u0435\u0442\u044B,\u041B\u0430\u0433\u0438,\u0421\u044A\u0435\u0445\u0430\u0432\u0448\u0443\u044E
    \u043A\u0430\u0440\u0442\u0438\u043D\u043A\u0443,\u043D\u0435\u0440\u0430\u0431\u043E\u0447\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438,\u0438 \u0442\u0434 \u0438 \u0442\u043F
    \u0432\u0441\u0435 \u0432 \u0432\u0430\u0448\u0435\u043C \u0440\u0430\u0441\u043F\u043E\u0440\u044F\u0436\u0435\u043D\u0438\u0438(\u0414\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u043A\u0440\u0438\u043D\u0448\u043E\u0442\u044B \u043F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0442\u0441\u044F).
    \n\u041F\u0440\u043E\u0448\u0443 \u0432\u0430\u0441 \u043D\u0435 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0442\u044C
    \u0434\u0430\u043D\u043D\u0443\u044E \u0438\u0433\u0440\u0443 \u0442\u0440\u0435\u0442\u044C\u0438\u043C
    \u043B\u0438\u0446\u0430\u043C, \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0445\u043E\u0442\u044C \u043A\u0430\u043A\u043E\u0435-\u043D\u0438\u0431\u0443\u0434\u044C
    \u0443\u0434\u0430\u0432\u043E\u043B\u044C\u0441\u0442\u0438\u0432\u0435 \u043E\u0442
    \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u0438
    \u0441\u043F\u0430\u0441\u0438\u0431\u043E \u0447\u0442\u043E \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442\u0435
    \u043F\u0440\u043E\u0435\u043A\u0442\u0443 \u0441\u0442\u0430\u0442\u044C \u043B\u0443\u0447\u0448\u0435,
    \u0434\u043B\u044F \u043C\u0435\u043D\u044F \u044D\u0442\u043E \u0432\u0430\u0436\u043D\u043E!!!\n\nP.S
    \u0412\u043D\u0443\u0442\u0440\u0438 \u0438\u0433\u0440\u044B \u0435\u0441\u0442\u044C
    \u043C\u0435\u043D\u044E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 Esc"
